generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                String    @id @default(cuid())
  shopifyOrderId    String    @unique
  shopifyOrderName  String    // es. "#1001"
  customerName      String
  customerPhone     String
  customerAddress   String
  products          Json      // array di { name: string, quantity: number, price: string }
  totalPrice        String
  status            Status    @default(PENDING)
  whatsappMessageId String?
  responseDeadline  DateTime  // createdAt + NO_RESPONSE_HOURS
  confirmedAt       DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([responseDeadline])
}

model GmailToken {
  id           String   @id @default("default")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Status {
  PENDING      // Leads
  CONFIRMED    // Leads Confermati
  NO_RESPONSE  // Leads No Response
  REJECTED     // Leads Non Confermati
}
